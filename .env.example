# GoFlexxi Intelligence — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Database (required) ─────────────────────────────────────────────────────
# Get this from Supabase: Project Settings → Database → Connection String → URI
# Use the "Session mode" (port 5432) connection string for Prisma
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── Google Drive Integration (optional) ─────────────────────────────────────
# The Google Drive folder ID (from the URL of the shared folder)
GOOGLE_DRIVE_FOLDER_ID="1g2XoVq-kZ2_70dkRcfN-JFovWyyjycdC"

# Paste the ENTIRE contents of your Google service account JSON key file here
# (all on ONE line — remove all line breaks from the JSON)
# Steps:
#   1. console.cloud.google.com → Enable Google Drive API
#   2. IAM & Admin → Service Accounts → Create → Keys → Add Key → JSON
#   3. Share the Drive folder with the service account's client_email (Viewer)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
